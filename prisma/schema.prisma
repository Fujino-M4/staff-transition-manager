// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ===== ツール利用者 =====
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  isAdmin      Boolean  @default(false) @map("is_admin")
  createdAt    DateTime @default(now()) @map("created_at")

  // relations
  createdEvents    HrEvent[]   @relation("CreatedBy")
  checkedTasks     EventTask[] @relation("DoneBy")
  memoUpdatedTasks EventTask[] @relation("MemoUpdatedBy")

  @@map("users")
}

// ===== 部署マスタ =====
model Department {
  id        String    @id @default(cuid())
  name      String    @unique
  sortOrder Int       @default(0) @map("sort_order")

  // relations
  events HrEvent[]

  @@map("departments")
}

// ===== イベント種別マスタ =====
model EventTypeDefinition {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("event_type_definitions")
}

// ===== タスクテンプレート（定義） =====
model TaskDefinition {
  id        String  @id @default(cuid())
  eventType String  @map("event_type")
  category  String  // DXS / AIM / HR / GA
  label     String
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active") // 論理削除用

  // relations
  eventTasks EventTask[]

  @@map("task_definitions")
}

// ===== 入退社・異動イベント =====
model HrEvent {
  id           String      @id @default(cuid())
  name         String                         // 対象者氏名
  employeeId   String?     @map("employee_id") // 社員番号（任意）
  email        String?                         // メールアドレス（任意）
  mobilePhone  String?     @map("mobile_phone")  // 携帯番号（任意）
  teamsPhone   String?     @map("teams_phone")   // TeamsPhone（任意）
  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?     @map("department_id")
  eventType    String      @map("event_type")
  targetDate   DateTime?   @map("target_date") // イベント実施日（任意）
  deadline     DateTime?   @map("deadline")     // 期限（任意）
  isPending    Boolean     @default(false) @map("is_pending") // 保留フラグ
  note         String?
  createdBy    User?       @relation("CreatedBy", fields: [createdById], references: [id])
  createdById  String?     @map("created_by")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at") // ゴミ箱（ソフト削除）

  // relations
  tasks EventTask[]

  @@map("hr_events")
}

// ===== イベントごとのタスク実績 =====
model EventTask {
  id        String  @id @default(cuid())
  event     HrEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   String  @map("event_id")
  taskDef   TaskDefinition? @relation(fields: [taskDefId], references: [id])
  taskDefId String? @map("task_def_id")

  // テンプレートからコピーして保持
  category  String
  label     String
  sortOrder Int     @default(0) @map("sort_order")

  // チェック状態
  isDone   Boolean   @default(false) @map("is_done")
  doneBy   User?     @relation("DoneBy", fields: [doneById], references: [id])
  doneById String?   @map("done_by")
  doneAt   DateTime? @map("done_at")

  // メモ
  memo            String?
  memoUpdatedBy   User?     @relation("MemoUpdatedBy", fields: [memoUpdatedById], references: [id])
  memoUpdatedById String?   @map("memo_updated_by")
  memoUpdatedAt   DateTime? @map("memo_updated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("event_tasks")
}
